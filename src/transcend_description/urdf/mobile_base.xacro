<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--  DIMENSIONS — measured from real rover  -->
  <xacro:property name="base_length"  value="0.25"   />  <!-- meters, front-back -->
  <xacro:property name="base_width"   value="0.14"   />  <!-- meters, left-right  -->
  <xacro:property name="base_height"  value="0.125"  />  <!-- meters, up-down     -->
  <xacro:property name="wheel_radius" value="0.022"  />  <!-- meters              -->
  <xacro:property name="wheel_length" value="0.018"  />  <!-- meters, thickness   -->€

  <!-- WHEEL MACRO -->
  <xacro:macro name="wheel_link" params="prefix">
    <link name="${prefix}_wheel_link">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_length}" />
        </geometry>
        <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
        <material name="gray" />
      </visual>
      <collision>
        <geometry>
          <sphere radius="${wheel_radius}" />
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0" />
      </collision>
      <xacro:cylinder_inertia m="1.0" r="${wheel_radius}" l="${wheel_length}"
          o_xyz="0 0 0" o_rpy="${pi / 2.0} 0 0" />
    </link>
  </xacro:macro>

  <!-- LINKS -->
  <link name="base_footprint" />

  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}" />
      </geometry>
      <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0" />
      <material name="green" />
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}" />
      </geometry>
      <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0" />
    </collision>
    <xacro:box_inertia m="5.0" x="${base_length}" y="${base_width}"
        z="${base_height}" o_xyz="0 0 ${base_height / 2.0}" o_rpy="0 0 0" />
  </link>

  <xacro:wheel_link prefix="front_left"  />
  <xacro:wheel_link prefix="front_right" />
  <xacro:wheel_link prefix="rear_right"  />
  <xacro:wheel_link prefix="rear_left"   />

  <!-- JOINTS -->
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint" />
    <child  link="base_link" />
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0" />
  </joint>

  <joint name="base_rear_right_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child  link="rear_right_wheel_link" />
    <origin xyz="${-base_length / 4.0} ${-(base_width + wheel_length) / 2.0} 0"
            rpy="0 0 0" />
    <axis xyz="0 1 0" />
  </joint>

  <joint name="base_rear_left_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child  link="rear_left_wheel_link" />
    <origin xyz="${-base_length / 4.0} ${(base_width + wheel_length) / 2.0} 0"
            rpy="0 0 0" />
    <axis xyz="0 1 0" />
  </joint>

  <joint name="base_front_left_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child  link="front_left_wheel_link" />
    <origin xyz="${base_length / 4.0} ${(base_width + wheel_length) / 2.0} 0"
            rpy="0 0 0" />
    <axis xyz="0 1 0" />
  </joint>

  <joint name="base_front_right_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child  link="front_right_wheel_link" />
    <origin xyz="${base_length / 4.0} ${-(base_width + wheel_length) / 2.0} 0"
            rpy="0 0 0" />
    <axis xyz="0 1 0" />
  </joint>

  <!-- LiDAR mount -->
  <link name="laser_frame">
    <visual>
      <geometry><cylinder length="0.052" radius="0.03"/></geometry>
      <origin xyz="0 0 0.026" rpy="0 0 0" />
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.052" radius="0.03"/></geometry>
      <origin xyz="0 0 0.026" rpy="0 0 0" />
    </collision>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="0 0 ${base_height}" rpy="0 0 0"/>
  </joint>

  <!-- ================================================================
       ros2_control hardware interface declaration
       The TranscendHardwareInterface plugin (transcend_hardware package)
       will be loaded by controller_manager at runtime.
       ================================================================ -->
  <ros2_control name="TranscendHardware" type="system">
    <hardware>
      <plugin>transcend_hardware/TranscendHardwareInterface</plugin>
    </hardware>

    <joint name="base_front_left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-12.9</param>
        <param name="max"> 12.9</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="base_front_right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-12.9</param>
        <param name="max"> 12.9</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="base_rear_left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-12.9</param>
        <param name="max"> 12.9</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="base_rear_right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-12.9</param>
        <param name="max"> 12.9</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>